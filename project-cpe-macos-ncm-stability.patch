+/// 等待 UDC 完成枚举，并读取实际协商速度。
+/// 常见值包括 high-speed（USB 2.0）和 super-speed（USB 3.x）。
+fn wait_for_udc_speed(udc_name: &str) -> Option<String> {
+    let speed_path = format!("/sys/class/udc/{}/current_speed", udc_name);
+
+    for _ in 0..20 {
+        if let Ok(speed) = fs::read_to_string(&speed_path) {
+            let speed = speed.trim().to_ascii_lowercase();
+            if !speed.is_empty() && speed != "unknown" {
+                return Some(speed);
+            }
+        }
+
+        std::thread::sleep(Duration::from_millis(250));
+    }
+
+    None
+}
+
+fn recommended_max_dl_pkts(config: &UsbModeConfig, speed: Option<&str>) -> u8 {
+    if config.configuration == "ncm"
+        && !matches!(speed, Some(value) if value.contains("super"))
+    {
+        // USB 2.0 + NCM 降低下行聚合，减少 PAMU3 突发和流控压力。
+        NCM_USB2_MAX_DL_PKTS
+    } else {
+        DEFAULT_MAX_DL_PKTS
+    }
+}
+
+/// PAMU3 的 open/post_init 会重设 max_dl_pkts，因此必须在 UDC 枚举完成后调优。
+fn tune_usb_link_after_enumeration(config: &UsbModeConfig, udc_name: &str) {
+    let speed = wait_for_udc_speed(udc_name);
+    let max_dl_pkts = recommended_max_dl_pkts(config, speed.as_deref());
+
+    if config.pamu3_protocol.is_some() && Path::new(PAMU3_MAX_DL_PKTS_PATH).exists() {
+        if let Err(error) = write_to_file(PAMU3_MAX_DL_PKTS_PATH, &max_dl_pkts.to_string()) {
+            eprintln!("Warning: failed to tune PAMU3 max_dl_pkts: {}", error);
+        }
+    }
+
+    // 仅对 NCM 禁用设备侧 runtime suspend，ECM/RNDIS 保持原行为。
+    if config.configuration == "ncm" {
+        let power_control_paths = [
+            format!("/sys/class/udc/{}/device/power/control", udc_name),
+            "/sys/class/net/usb0/device/power/control".to_string(),
+        ];
+
+        for path in power_control_paths {
+            if Path::new(&path).exists() {
+                if let Err(error) = write_to_file(&path, "on") {
+                    eprintln!("Warning: failed to keep USB device awake via {}: {}", path, error);
+                }
+            }
+        }
+    }
+
+    let speed_name = speed.as_deref().unwrap_or("unknown");
+    let report = format!(
+        "mode={}\nspeed={}\nmax_dl_pkts={}\n",
+        config.configuration, speed_name, max_dl_pkts,
+    );
+    let _ = fs::write("/tmp/usb_link_tuning", &report);
+    eprintln!("USB link tuning: {}", report.replace('\n', ", "));
+}
+
