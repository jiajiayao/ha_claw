-    }
+    // 5. max_dl_pkts 延后到 UDC 枚举与 PAMU3 post_init 完成后设置。
     
     // 6. 发送 AT 指令控制 USB 共享模式
-    let _ = set_usb_share_mode(config.usb_share_enable);
+    if let Err(error) = set_usb_share_mode(config.usb_share_enable) {
+        eprintln!("Warning: failed to set USB share mode: {}", error);
+    }
     
     // 7. 确保 configfs 已挂载
     let _ = Command::new("mount")
@@ -536,7 +613,8 @@ pub fn switch_usb_mode_advanced(mode: u8) -> Result<(), String> {
         .map_err(|e| format!("Failed to enable UDC: {}", e))?;
     
-    // 19. 等待 USB 设备被主机识别
-    std::thread::sleep(std::time::Duration::from_millis(1000));
+    // 19. 等待 USB 设备被主机识别，并按实际协商速度调优 PAMU3。
+    std::thread::sleep(Duration::from_millis(250));
+    tune_usb_link_after_enumeration(&config, &udc_name_cached);
     
     // 20. 配置网络接口
     configure_usb_network()?;
@@ -641,5 +720,18 @@ fn configure_usb_network() -> Result<(), String> {
-    // 等待接口出现
-    std::thread::sleep(std::time::Duration::from_millis(500));
+    // macOS 重新枚举复合 USB 设备可能明显慢于 Windows。
+    // 先等待 usb0 真正出现，再运行 connmanctl，避免初始化命令被静默丢弃。
+    for retry in 0..40 {
+        if Path::new("/sys/class/net/usb0").exists() {
+            break;
+        }
+
+        if retry < 39 {
+            std::thread::sleep(Duration::from_millis(250));
+        }
+    }
+
+    if !Path::new("/sys/class/net/usb0").exists() {
+        return Err("USB network interface usb0 did not appear after 10 seconds".to_string());
+    }
     
     // 1. 配置 connman gadget tethering
     // 先关闭再重新启用（避免 "Already enabled" 错误）
@@ -713,9 +805,10 @@ fn configure_usb_network() -> Result<(), String> {
         .args(["link", "set", "dev", "usb0", "up"])
         .output();
     
-    // 添加默认路由（用于主机端访问）
+    // usb0 是 CPE 向主机提供网络的 LAN，不应把设备默认路由指回主机。
+    // 清理旧版本可能留下的错误路由；不存在时忽略错误。
     let _ = Command::new("ip")
-        .args(["route", "add", "default", "via", "192.168.66.2"])
+        .args(["route", "del", "default", "via", USB_HOST_GATEWAY])
         .output();
     
     // 3. 关闭 sipa_usb0 接口（IPA USB 接口，避免冲突）
@@ -733,5 +827,18 @@ fn configure_usb_network() -> Result<(), String> {
         .args(["-c", "ifconfig > /dev/kmsg 2>/dev/null"])
         .output();
+
+    // 验证关键地址确实已经生效；原实现即使命令失败也会返回 Ok。
+    let interface_state = Command::new("ifconfig")
+        .arg("usb0")
+        .output()
+        .map_err(|e| format!("Failed to verify usb0: {}", e))?;
+    let interface_text = String::from_utf8_lossy(&interface_state.stdout);
+    if !interface_state.status.success() || !interface_text.contains(USB_INTERFACE_IP) {
+        return Err(format!(
+            "usb0 does not have expected address {} after configuration",
+            USB_INTERFACE_IP,
+        ));
+    }
     
     Ok(())
 }
